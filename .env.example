# Скопируется автоматически скриптом deploy/install.sh, если файла .env ещё нет.
# Замените значения на свои перед первым запуском.

SECRET_KEY=замените-на-случайный-ключ-минимум-50-символов
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# После получения SSL-сертификата (шаг 4 install.sh) укажите https-адреса:
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SECURE_SSL_REDIRECT=True

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
